---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-12 pb-8">
      <h1 class="hero-title mb-4 text-4xl">
        Ritesh Goru
      </h1>
      <p class="text-foreground-secondary text-lg italic mb-6">
        Notes on machine learning, optimization, and more
      </p>

      <p class="text-base leading-relaxed">
        I'm currently working at DevRev. I completed my undergraduate degree in Electrical Engineering at IIT Bombay. 
        I'm interested in Stochastic Approximation, MCMC techniques for Optimisation and Bayesian Learning Theory.
      </p>
      <p class="mt-4 text-base">
        Check out my <LinkButton
          class="underline underline-offset-2 hover:opacity-70"
          href="/about/"
        >
          about page
        </LinkButton> for more info.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex items-center gap-4">
            <Socials />
            <a
              target="_blank"
              href="/rss.xml"
              class="opacity-60 hover:opacity-100"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss width={20} height={20} />
            </a>
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-8">
            <h2 class="section-title text-3xl mb-2">
              Featured
            </h2>
            <p class="text-foreground-secondary italic mb-6">Selected writings</p>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-8">
          <h2 class="section-title text-3xl mb-2">
            Recent Posts
          </h2>
          <p class="text-foreground-secondary italic mb-6">Latest notes and summaries</p>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/" class="text-foreground hover:opacity-70">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .hero-title,
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
